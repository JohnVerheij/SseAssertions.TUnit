<?xml version="1.0" encoding="utf-8"?>
<!--
  Local-feed configuration for the external-consumer smoke-test project. Adds the project's
  pack-output directory (artifacts at the repo root) as a NuGet source ahead of nuget.org so
  the smoke test consumes the just-built SseAssertions / SseAssertions.TUnit nupkgs
  rather than any stale published version. The local feed is empty until the CI step runs:
  dotnet pack ... output ./artifacts. In normal local dev, run the same pack command before
  restore.

  The packageSourceMapping block is required because the root nuget.config maps every
  package to nuget.org. We override here to route SseAssertions.* to the local feed and
  everything else to nuget.org.
-->
<configuration>
  <packageSources>
    <clear />
    <add key="local-pack" value="../../artifacts" />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
  <packageSourceMapping>
    <clear />
    <packageSource key="local-pack">
      <package pattern="SseAssertions" />
      <package pattern="SseAssertions.TUnit" />
    </packageSource>
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
  </packageSourceMapping>
</configuration>
